# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# Everything here is read server-side only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Admin authentication ─────────────────────────────────────────────────────
# Secret used to sign the admin session JWT. Use a long random string.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Admin login credentials. The username you type at /admin/login is compared
# (case-insensitively) against ADMIN_EMAIL, and the password against the bcrypt
# hash below. Generate the hash with:
#   node -e "require('bcryptjs').hash('YourSecurePassword', 12).then(console.log)"
#
# NOTE: if BOTH of these are left unset, the app falls back to a hard-coded dev
# login (username "ichattiesburg" / password "3223"). ALWAYS set these in prod.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# ── Durable content storage (configure at least ONE for production) ───────────
# Admin edits are written through src/lib/remote-storage.ts. On serverless the
# local /tmp fallback is per-instance and does NOT persist, so you need a shared
# backend or your changes will vanish between requests.

# Option A — Upstash Redis / Vercel KV (recommended: instant, no redeploys).
# Vercel KV injects the KV_* names; a raw Upstash DB uses the UPSTASH_* names.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Option B — GitHub Contents API (commits each save back to the repo).
# Fine-grained PAT with "Contents: Read and write" on the target repo.
# The target repo/branch are hard-coded in src/lib/remote-storage.ts
# (GH_OWNER / GH_REPO / GH_BRANCH) — update those when you fork.
# GITHUB_TOKEN=            # GH_TOKEN and GITHUB_PAT are also accepted

# ── Optional: Stripe donation checkout ───────────────────────────────────────
# Only needed if you wire the (currently dormant) /api/donate Stripe route.
# The shipped /donate page uses Zeffy embeds instead and needs nothing here.
# STRIPE_SECRET_KEY=

# ── Optional / legacy: Postgres ──────────────────────────────────────────────
# src/lib/db.ts + schema.sql are legacy and unused by the running app.
# DATABASE_URL=
